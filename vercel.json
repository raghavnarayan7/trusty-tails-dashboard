{
  "rewrites": [
    { "source": "/analytics", "destination": "/analytics.html" }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "analytics.trustytails.vet" }],
      "destination": "https://analytics.trustytails.vet/analytics",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/slides/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET" }
      ]
    }
  ]
}
